# Free API keys (all require free registration)
FRED_API_KEY=your_fred_key_here           # https://fred.stlouisfed.org/docs/api/api_key.html
FMP_API_KEY=your_fmp_key_here             # https://financialmodelingprep.com/developer
TWELVE_DATA_API_KEY=your_12d_key_here     # https://twelvedata.com
FINNHUB_API_KEY=your_finnhub_key_here     # https://finnhub.io/register (free: 60 calls/min)
REDDIT_CLIENT_ID=your_reddit_client_id   # https://www.reddit.com/prefs/apps
REDDIT_CLIENT_SECRET=your_reddit_secret  # (from same Reddit app as CLIENT_ID)
REDDIT_USER_AGENT=NeuralQuant/0.1

# Supabase (Phase 4 — Pillar A auth + watchlists)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=                      # HS256 legacy secret (preferred for fast verify)
# SUPABASE_JWKS_URL=                      # or ES256 JWKS URL (falls back to <SUPABASE_URL>/auth/v1/.well-known/jwks.json)
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_DB_URL=                          # postgres connection string for schema migrations (pooler URL recommended)

# Anthropic (Phase 2)
ANTHROPIC_API_KEY=
