# NeuralQuant — environment template. Copy to .env and fill. NO real values here.

# === LLM (one of the two paths required for PARA-DEBATE / Ask AI) ===
ANTHROPIC_API_KEY=                        # sk-ant-... (direct Anthropic API)
USE_BEDROCK=false                         # true = route LLM calls through AWS Bedrock instead
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
BEDROCK_RUNTIME_REGION=                   # optional override for Bedrock runtime region
NQ_QUERY_MODEL=                           # optional model override for Ask AI
NQ_FAST_MODEL=                            # optional model override for fast paths

# === Market data ===
FMP_API_KEY=                              # PRIMARY US data — https://financialmodelingprep.com ($49/mo premium)
FRED_API_KEY=                             # Free — https://fred.stlouisfed.org/docs/api/api_key.html
FINNHUB_API_KEY=                          # Free tier — https://finnhub.io/register (60 calls/min)
TWELVE_DATA_API_KEY=                      # Optional — https://twelvedata.com
REDDIT_CLIENT_ID=                         # Optional sentiment — https://www.reddit.com/prefs/apps
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=NeuralQuant/0.1
OPENBB_ENABLED=false                      # true = proxy Terminal endpoints to OpenBB Platform
OPENBB_API_URL=                           # OpenBB Platform base URL (Render service or tunnel)

# === Persistence ===
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=                      # HS256 legacy secret (preferred for fast verify)
# SUPABASE_JWKS_URL=                      # or ES256 JWKS URL (falls back to <SUPABASE_URL>/auth/v1/.well-known/jwks.json)
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_DB_URL=                          # postgres connection string for migrations (pooler URL recommended)
SUPABASE_WEBHOOK_SECRET=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/neuralquant   # docker-compose local default

# === Payments (optional for demo) ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_INVESTOR_US=
STRIPE_PRICE_INVESTOR_IN=
STRIPE_PRICE_PRO_US=
STRIPE_PRICE_PRO_IN=
STRIPE_PRICE_MORGAN_US=
STRIPE_PRICE_MORGAN_IN=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_LIVE=false
PAYPAL_WEBHOOK_ID=
PAYPAL_PLAN_INVESTOR_USD=
PAYPAL_PLAN_PRO_USD=
PAYPAL_PLAN_API_USD=

# === Email / Voice (optional for demo) ===
RESEND_API_KEY=
RESEND_FROM=NeuralQuant <alerts@neuralquant.co>
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# === Trading daemon (optional — paper trading) ===
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
TRADE_ENABLED=false
DRY_RUN=true
DAILY_LOSS_LIMIT=
MAX_BET_DEFAULT=
MAX_POSITIONS_DEFAULT=

# === Ops / security ===
CRON_SECRET=                              # auth for POST /cron endpoints
SMOKE_TEST_SECRET=                        # auth bypass for /health/smoke
CORS_ORIGIN_REGEX=
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ENVIRONMENT=development

# === Modes ===
DEMO_MODE=false                           # true = run fully from bundled snapshot, zero external keys
RENDER=false                              # true on Render cloud — disables yfinance paths
