# Public environment variables for the Next.js frontend.
# See ../../.env.example for the full annotated template.

NEXT_PUBLIC_API_URL=https://your-render-url.onrender.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=           # optional Plausible analytics domain
NEXT_PUBLIC_TEAM_HUB_URL=               # optional team hub URL
